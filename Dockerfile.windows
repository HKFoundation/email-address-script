# 用于在 macOS 上通过 Docker 跨平台打包 Windows .exe
# 基础镜像内置 Wine + Windows Python + PyInstaller，可在 Linux 容器中直接产出 .exe

FROM cdrx/pyinstaller-windows:python3

# 镜像维护者信息
LABEL maintainer="bobo"
LABEL description="Cross-build Windows .exe for 飞书邮箱提取工具 on macOS via Docker"

# 设置工作目录
WORKDIR /app

# 默认启动命令（在 build_windows_docker.sh 中会被覆盖）
CMD ["pyinstaller", "--version"]
